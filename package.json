{
    "name": "voboost-install",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "tauri:dev": "tauri dev",
        "tauri:build": "tauri build",
        "dev": "vite dev --config config/vite.config.ts",
        "build": "tsc -p config/tsconfig.json --noEmit && vite build --config config/vite.config.ts",
        "clean": "rm -rf build/*.dmg",
        "release": "npm run clean && npm run build && node src/build/release.js",
        "preview": "vite preview --config config/vite.config.ts",
        "tauri": "tauri",
        "lint": "eslint -c config/eslint.config.mjs src --fix",
        "format": "prettier --config config/prettier.config.mjs --write 'src/**/*.{ts,tsx,css}'",
        "typecheck": "tsc -p config/tsconfig.json --noEmit",
        "test": "vitest --config config/vite.config.ts",
        "test:coverage": "vitest --coverage",
        "test:ui": "testplane"
    },
    "dependencies": {
        "@fluentui/react-components": "^9.56.0",
        "@fluentui/react-icons": "^2.0.260",
        "@tauri-apps/api": "^2.2.0",
        "@tauri-apps/plugin-cli": "^2.4.1",
        "@tauri-apps/plugin-dialog": "^2.6.0",
        "@tauri-apps/plugin-os": "^2.2.0",
        "i18next": "^25.8.13",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-i18next": "^16.5.4",
        "react-use-wizard": "^2.3.0",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@asamuzakjp/css-color": "^4.1.2",
        "@csstools/css-calc": "^3.1.1",
        "@eslint/js": "^9.39.3",
        "@tauri-apps/cli": "^2.2.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.3.4",
        "esbuild": "^0.27.3",
        "eslint": "^9.39.3",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.3.0",
        "jsdom": "^27.0.1",
        "prettier": "^3.8.1",
        "testplane": "^8.40.10",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^6.0.0",
        "vite-plugin-markdown": "^2.2.0",
        "vitest": "^4.0.18",
        "voboost-codestyle": "file:../voboost-codestyle"
    }
}
